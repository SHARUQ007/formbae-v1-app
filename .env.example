# Next.js origin that serves the /api/mobile BFF.
# Android emulator -> http://10.0.2.2:3000
# iOS simulator    -> http://127.0.0.1:3000
# Physical device  -> http://<YOUR_MACHINE_LAN_IP>:3000  (e.g. http://192.168.1.10:3000)
API_BASE_URL=http://10.0.2.2:3000

# Public site for web payment fallback / deep links
SITE_URL=https://formbae.in

# Razorpay public key (test or live). Used by the native checkout SDK.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
